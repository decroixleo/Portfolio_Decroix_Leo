    .form-success { display: none; background: rgba(48,232,192,0.08); border: 1px solid rgba(48,232,192,0.25); border-radius: 10px; padding: 1rem; text-align: center; color: var(--accent3); font-size: .875rem; font-weight: 500; margin-top: 1rem; }
