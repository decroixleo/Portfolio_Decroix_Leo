    .veille-desc { color: var(--muted); font-size: .8rem; line-height: 1.5; }
    .veille-icon { width: 40px; height: 40px; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .rss-sources { padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); }
