  var input = document.getElementById("veille" + v + "-url-input");
  var url = input.value.trim();
  if (!url) return;
  var name = prompt("Nom court de cette source ?") || url;
  sources[v].push({ name: name, url: url });
  input.value = "";
  renderChips(v);
  loadFeed(v);
}

function removeSource(v, i) {
  sources[v].splice(i, 1);
  renderChips(v);
  loadFeed(v);
}

function loadFeed(v) {
  var el = document.getElementById("veille" + v + "-feed");
  el.innerHTML = '<div class="rss-loading">Chargement...</div>';
  if (!sources[v].length) {
    el.innerHTML = '<p class="rss-error">Aucune source configuree.</p>';
    return;
  }
  var promises = sources[v].map(function(s) {
    return fetch(PROXY + encodeURIComponent(s.url))
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status !== "ok") throw new Error("err");
        return data.items.slice(0, 5).map(function(item) {
          var d = "";
          try { d = new Date(item.pubDate).toLocaleDateString("fr-FR", {day:"numeric",month:"short",year:"numeric"}); } catch(e) {}
          return { title: item.title, link: item.link, date: d, source: data.feed.title || s.name };
        });
      });
  });
  Promise.all(promises.map(function(p) { return p.catch(function() { return []; }); }))
    .then(function(results) {
      var items = [].concat.apply([], results)
        .sort(function(a, b) { return new Date(b.date) - new Date(a.date); })
        .slice(0, 8);
      if (!items.length) {
        el.innerHTML = '<p class="rss-error">Impossible de charger les articles. Verifie les URLs.</p>';
        return;
      }
      el.innerHTML = items.map(function(item) {
        return '<div class="rss-item"><a href="' + item.link + '" target="_blank" rel="noopener">' + item.title + '</a>' +
          '<div class="rss-item-meta"><span class="rss-source-label">' + item.source + '</span><span class="rss-date">' + item.date + '</span></div></div>';
      }).join("");
    });
}

