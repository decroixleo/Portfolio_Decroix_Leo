    .footer-sub { color: var(--muted2); font-size: .85rem; margin-bottom: 1.5rem; }
    .footer-links { display: flex; justify-content: center; gap: 1.25rem; flex-wrap: wrap; margin-bottom: 2rem; }
    .footer-links a { color: var(--muted); font-size: .85rem; font-weight: 500; text-decoration: none; display: flex; align-items: center; gap: 6px; transition: color .2s; }
    .footer-links a:hover { color: var(--accent); }
    .footer-copy { color: var(--muted2); font-size: .75rem; }

    @media (max-width: 768px) {
      nav { padding: 0 1.25rem; }
      .nav-links { gap: 1rem; }
      .about-grid, .projets-grid, .veille-grid, .contact-layout { grid-template-columns: 1fr; }
      .info-grid, .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
